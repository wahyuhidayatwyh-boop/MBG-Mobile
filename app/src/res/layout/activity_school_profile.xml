<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C"
    tools:context=".SchoolProfileActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerProfile"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#103A5C"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROFIL SEKOLAH"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:alpha="0.7" />

        <TextView
            android:id="@+id/tvProfileSchoolNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Memuat..."
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:textSize="24sp" />
    </LinearLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerProfile"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- Section: Info Lokasi (Penting untuk Kurir) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOKASI PENGIRIMAN"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F8FAFC"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alamat Navigasi Kurir"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold"/>
                    <TextView
                        android:id="@+id/tvProfileAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="2dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Koordinat Lat" android:textColor="#94A3B8" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                            <TextView android:id="@+id/tvProfileLat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0" android:textColor="#103A5C" android:textSize="13sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Koordinat Lng" android:textColor="#94A3B8" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                            <TextView android:id="@+id/tvProfileLng" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0" android:textColor="#103A5C" android:textSize="13sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Mitra & Akun -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KONEKSI MITRA MBG"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F8FAFC"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jenjang Sekolah" android:textColor="#94A3B8" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:id="@+id/tvProfileLevel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1E293B" android:textSize="14sp" android:layout_marginTop="2dp" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Akun" android:textColor="#94A3B8" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                    <TextView android:id="@+id/tvProfileEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1E293B" android:textSize="14sp" android:layout_marginTop="2dp" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_info" app:tint="#103A5C"/>
                        <TextView android:id="@+id/tvProfileVendor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Vendor: --" android:textColor="#1E293B" android:fontFamily="sans-serif-bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_directions" app:tint="#16A34A"/>
                        <TextView android:id="@+id/tvProfileDriver" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Kurir: --" android:textColor="#1E293B" android:fontFamily="sans-serif-bold" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Data Siswa (Penamaan Baru) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RINGKASAN PENERIMA MANFAAT"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0FDF4"
                app:strokeWidth="1dp"
                app:strokeColor="#DCFCE7">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Seluruh Siswa" android:textColor="#16A34A" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                            <TextView android:id="@+id/tvProfileTotalSiswa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Anak" android:textColor="#16A34A" android:textSize="24sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#16A34A" android:alpha="0.2"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCFCE7" android:layout_marginVertical="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gizi Kategori A" android:textColor="#16A34A" android:textSize="10sp" android:fontFamily="sans-serif-bold"/>
                            <TextView android:id="@+id/tvProfileCountA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Anak" android:textColor="#16A34A" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gizi Kategori B" android:textColor="#16A34A" android:textSize="10sp" android:fontFamily="sans-serif-bold"/>
                            <TextView android:id="@+id/tvProfileCountB" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Anak" android:textColor="#16A34A" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogoutSchool"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="KELUAR APLIKASI"
                android:textColor="#BE123C"
                app:backgroundTint="#FFF1F2"
                app:cornerRadius="16dp"
                android:fontFamily="sans-serif-black"
                app:elevation="0dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Copy -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <View android:id="@+id/navHomeProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackground" />
            <View android:id="@+id/navMenuProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackground" />
            <View android:id="@+id/navHistoryProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="?attr/selectableItemBackground" />
            <View android:id="@+id/navAccountProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F1F5F9" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>