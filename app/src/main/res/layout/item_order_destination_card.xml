<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvDestSchoolName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA SEKOLAH"
                android:textColor="@color/mbg_green_dark"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvDestTotalPorsi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0 Porsi"
                android:textColor="@color/mbg_green_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginVertical="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RINCIAN KELAS / UNIT:"
            android:textColor="#94A3B8"
            android:textSize="9sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/containerPorsiDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>