<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp"
    app:cardForegroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F1F5F9">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/sisa"
                android:scaleType="centerCrop"
                android:contentDescription="Sisa Icon" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvSisaSchoolName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Sekolah"
                android:textColor="#1E293B"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvSisaInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 Porsi Sisa - Siswa Sakit"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvSisaAllocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alokasi: Staf Sekolah"
                android:textColor="@color/mbg_green_primary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/tvSisaDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari ini"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>