<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="40dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_accent"
            android:backgroundTint="#FFF1F2">
            <ImageView
                android:id="@+id/ivDeleteIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#E11D48"
                android:contentDescription="Delete Icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvDeleteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Hapus Data"
            android:textColor="#1E293B"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvDeleteMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Apakah Anda yakin ingin menghapus data ini? Tindakan ini tidak dapat dibatalkan."
            android:textColor="#64748B"
            android:textSize="13sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDelete"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="BATAL"
                android:textColor="#64748B"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmDelete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:layout_marginStart="6dp"
                android:text="HAPUS"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#E11D48"
                android:textColor="@color/white"
                app:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>