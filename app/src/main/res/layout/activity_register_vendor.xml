<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".RegisterVendorActivity">

    <!-- Motif Background -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginTop="-250dp"
        android:layout_marginEnd="-200dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnToolbarBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/mbg_slate_800"
                android:contentDescription="Kembali" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REGISTRASI MITRA"
                android:textColor="@color/mbg_green_dark"
                android:fontFamily="sans-serif-black"
                android:textSize="11sp"
                android:letterSpacing="0.1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendaftaran Vendor"
                android:textColor="@color/mbg_slate_900"
                android:fontFamily="sans-serif-black"
                android:textSize="22sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- A. IDENTITAS USAHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A. IDENTITAS USAHA &amp; PEMILIK"
                android:textColor="@color/mbg_slate_400"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Usaha / Dapur"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVendorName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Nama Lengkap Pemilik"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOwnerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="NIB"
                            app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNIB"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="NPWP (Ops)"
                            app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNPWP"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Alamat Lengkap Dapur"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGetLocation"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="TENTUKAN TITIK LOKASI (GPS)"
                        android:textColor="#0369A1"
                        app:backgroundTint="#F0F9FF"
                        app:icon="@android:drawable/ic_menu_mylocation"
                        app:iconTint="#0369A1"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- B. PERIZINAN & SERTIFIKASI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B. BERKAS &amp; PERIZINAN (INTI)"
                android:textColor="@color/mbg_slate_400"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchHalal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Memiliki Sertifikat Halal?"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/mbg_slate_800"
                        android:paddingHorizontal="8dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins">

                        <!-- Halal Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnUploadHalal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E2E8F0">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center" android:orientation="vertical">
                                <ImageView android:id="@+id/ivCheckHalal" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_camera" app:tint="#64748B"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sertif Halal" android:textColor="#475569" android:fontFamily="sans-serif-bold" android:textSize="11sp" android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- PIRT Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnUploadPIRT"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E2E8F0">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center" android:orientation="vertical">
                                <ImageView android:id="@+id/ivCheckPIRT" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_camera" app:tint="#64748B"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PIRT / BPOM" android:textColor="#475569" android:fontFamily="sans-serif-bold" android:textSize="11sp" android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Hygiene Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnUploadHygiene"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E2E8F0">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center" android:orientation="vertical">
                                <ImageView android:id="@+id/ivCheckHygiene" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_camera" app:tint="#64748B"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laik Hygiene" android:textColor="#475569" android:fontFamily="sans-serif-bold" android:textSize="11sp" android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Izin Ops Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnUploadIzinOps"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E2E8F0">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center" android:orientation="vertical">
                                <ImageView android:id="@+id/ivCheckIzinOps" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_camera" app:tint="#64748B"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Izin Operasional" android:textColor="#475569" android:fontFamily="sans-serif-bold" android:textSize="11sp" android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </GridLayout>

                    <!-- Foto Dapur Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnUploadFotoDapur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:gravity="center" android:orientation="horizontal">
                            <ImageView android:id="@+id/ivCheckFotoDapur" android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_camera" app:tint="#64748B"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="FOTO AREA DAPUR PRODUKSI" android:textColor="#475569" android:fontFamily="sans-serif-black" android:textSize="12sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- C. KAPASITAS & OPERASIONAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C. KAPASITAS &amp; OPERASIONAL"
                android:textColor="@color/mbg_slate_400"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Kapasitas Produksi (Porsi/Hari)"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTargetPorsi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Jumlah Tenaga Kerja"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmployeeCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Jam Operasional"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOperatingHours"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Jenis Menu Yang Bisa Disediakan"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMenuTypes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Total Capital / Modal Produksi (Rp)"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTotalCapital"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- D. COMPLIANCE & AKUN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D. COMPLIANCE &amp; LOGIN AKUN"
                android:textColor="@color/mbg_slate_400"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <CheckBox android:id="@+id/cbGizi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Setuju Standar Gizi (Karbo, Protein, Sayur)" android:textSize="12sp" android:textColor="@color/mbg_slate_700"/>
                    <CheckBox android:id="@+id/cbSLA" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Komitmen SLA Distribusi Tepat Waktu" android:textSize="12sp" android:textColor="@color/mbg_slate_700"/>
                    <CheckBox android:id="@+id/cbAudit" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Persetujuan Audit Digital &amp; Sidak" android:textSize="12sp" android:textColor="@color/mbg_slate_700"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Akun"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Password"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp"
                        app:passwordToggleEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="DAFTAR VENDOR (AJUKAN APPROVAL)"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp"
                android:layout_marginTop="32dp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/mbg_green_dark"
                android:elevation="4dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:visibility="gone"
        android:indeterminateTint="@color/mbg_green_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>