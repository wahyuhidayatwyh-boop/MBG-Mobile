<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerOrder"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackOrderDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JADWAL MENDATANG"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:alpha="0.7" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rincian Pesanan"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerOrder"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- Carousel Foto Menu -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderPhotos"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpOrderMenuPhotos"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tlOrderPhotoIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="12dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginBottom="12dp"
                        android:background="@android:color/transparent"
                        app:tabBackground="@drawable/tab_indicator_dot"
                        app:tabGravity="center"
                        app:tabIndicatorHeight="0dp"
                        app:tabMaxWidth="12dp"
                        app:tabRippleColor="@null" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvOrderMenuName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Memuat Menu..."
                android:textColor="#1E293B"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvOrderVendorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="24dp"/>

            <!-- Info Porsi Counter -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F8FAFC"
                app:strokeWidth="1.5dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RINCIAN ALOKASI PORSI"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp"/>

                    <!-- Gizi Kategori A -->
                    <LinearLayout
                        android:id="@+id/layoutOrderGiziA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gizi Kategori A"
                            android:textColor="#1E293B"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvOrderPorsiA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Porsi"
                            android:textColor="#103A5C"
                            android:fontFamily="sans-serif-black"
                            android:textSize="16sp"/>
                    </LinearLayout>

                    <!-- Gizi Kategori B -->
                    <LinearLayout
                        android:id="@+id/layoutOrderGiziB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gizi Kategori B"
                            android:textColor="#1E293B"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvOrderPorsiB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Porsi"
                            android:textColor="#103A5C"
                            android:fontFamily="sans-serif-black"
                            android:textSize="16sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0"
                        android:layout_marginVertical="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL TERIMA"
                            android:textColor="#103A5C"
                            android:fontFamily="sans-serif-black"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvOrderTotalPorsi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#103A5C"
                            android:fontFamily="sans-serif-black"
                            android:textSize="20sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>