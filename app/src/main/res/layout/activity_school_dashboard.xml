<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".SchoolDashboardActivity">

    <!-- Background Image for Header area -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bgrounddsb"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Overlay to ensure text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="#50000000"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Header Section (Content) -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <!-- Logo MBG on the Left with White Background -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="48dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="6dp"
                    android:src="@drawable/logo_mbg"
                    android:scaleType="fitCenter" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Profile Info on the Right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvGreetingSchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Halo, Guru!"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#FF000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="2" />
                <TextView
                    android:id="@+id/tvSchoolName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Sekolah"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:shadowColor="#FF000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="2" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TARGET HARI INI"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:shadowColor="#FF000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2" />
            <TextView
                android:id="@+id/tvTargetInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="450 Porsi"
                android:textColor="@color/white"
                android:textSize="38sp"
                android:fontFamily="sans-serif-black"
                android:shadowColor="#FF000000"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="3" />
        </LinearLayout>
    </LinearLayout>

    <!-- Floating Action Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/floatingActionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="@id/headerContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/btnInputSiswa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/mbg_green_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Input Siswa"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnRateVendor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivRateVendorIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/mbg_green_primary" />
                <TextView
                    android:id="@+id/tvRateVendorLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Rating"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnRateDriver"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="@color/mbg_green_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kurir"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnHelpTop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/sch_bantuan_klik"
                    app:tint="@color/mbg_green_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Bantuan"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Content Body -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:clipToPadding="false"
        android:paddingTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fitur Layanan"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp" />

            <!-- Redesigned Feature Grid (2 Columns like Vendor Dashboard) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="24dp">

                <!-- Laporan (Anomali) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAnomali"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/anomali"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Laporan"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anomali &amp; Masalah"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sisa Makanan -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnInputSisaFeature"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/sisa"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Sisa Makanan"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update Porsi Sisa"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Retur -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnRetur"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/pengembalian"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Retur"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pengembalian Wadah"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Data Alergi -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAlergiFeature"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/alergi"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Data Alergi"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Info Alergi Siswa"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- QR Sekolah -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnShowSchoolQR"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/qr_barcode"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="QR Sekolah"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan Kehadiran"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cek AI -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAIScanFeature"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/sch_ai"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0F2FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Cek AI"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verifikasi Menu"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Menu Hari Ini -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menu Hari Ini"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:id="@+id/btnLihatSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Lihat Semua"
                    android:textColor="@color/mbg_green_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold" />
            </RelativeLayout>

            <!-- Status Laporan Card (Dinamis) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFF7ED"
                app:strokeWidth="1dp"
                app:strokeColor="#FFEDD5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#D97706"/>
                    <TextView
                        android:id="@+id/tvPhaseTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="SEDANG DIMASAK"
                        android:textColor="#92400E"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Container for Dynamic Category Cards -->
            <LinearLayout
                android:id="@+id/containerTodayMenus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Navigation Bar - Bottom Sticky -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <!-- Beranda -->
            <LinearLayout
                android:id="@+id/navBeranda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_home_selector" />
                <TextView
                    android:id="@+id/tvNavHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Beranda"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- Menu (Upcoming) -->
            <LinearLayout
                android:id="@+id/navMenu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavMenu"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_menu_selector" />
                <TextView
                    android:id="@+id/tvNavMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Menu"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Riwayat (Dipindah dari Bantuan) -->
            <LinearLayout
                android:id="@+id/navHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavHistory"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_history_selector" />
                <TextView
                    android:id="@+id/tvNavHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Riwayat"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Akun -->
            <LinearLayout
                android:id="@+id/navAkun"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavAccount"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_account_selector" />
                <TextView
                    android:id="@+id/tvNavAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Akun"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>