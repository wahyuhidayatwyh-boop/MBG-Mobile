<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Smaller Icon Indicator -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconContainer"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#F0F9FF"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivDialogIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#0284C7" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Konfirmasi"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#1E293B"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/tvDialogMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Pesan konfirmasi di sini."
            android:textSize="13sp"
            android:textColor="#64748B"
            android:textAlignment="center"
            android:lineSpacingExtra="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="MULAI SEKARANG"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/mbg_green_dark"
                android:textColor="@color/white"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="2dp"
                android:text="Batal"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>