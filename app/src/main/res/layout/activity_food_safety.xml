<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".FoodSafetyActivity">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-320dp"
        android:layout_marginEnd="-280dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.05"
        app:layout_anchorGravity="top|end" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">
                <ImageView
                    android:id="@+id/btnBackSafety"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_wrapper"
                    android:backgroundTint="#F1F5F9"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/mbg_green_dark"
                    android:contentDescription="Back" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="sans-serif-black"
                    android:text="4. KEAMANAN PANGAN"
                    android:textColor="@color/mbg_green_dark"
                    android:textSize="18sp"
                    android:letterSpacing="0.02" />
            </RelativeLayout>

            <!-- Card Informasi -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FEF2F2"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FEE2E2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="#EF4444" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SIMPAN SAMPEL MAKANAN"
                            android:textColor="#991B1B"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Ambil 1 boks utuh sebagai sampel audit gizi."
                            android:textColor="#B91C1C"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 1. FOTO SAMPEL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUKTI PENYIMPANAN SAMPEL"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTakePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC"
                        android:clickable="true"
                        android:focusable="true">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/ivSamplePhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_camera"
                                android:padding="75dp"
                                app:tint="#CBD5E1"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTakePhoto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:text="AMBIL FOTO"
                                app:cornerRadius="12dp"
                                app:backgroundTint="@color/mbg_green_dark" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pastikan segel boks terlihat jelas dalam foto."
                        android:textAlignment="center"
                        android:textColor="#FFFFFF"
                        android:alpha="0.8"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. INPUT SUHU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONITORING SUHU CHILLER"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Suhu Aktual (°C)"
                        app:hintTextColor="#FFFFFF"
                        app:placeholderTextColor="#FFFFFF"
                        app:boxStrokeColor="#FFFFFF"
                        app:boxStrokeWidth="1dp"
                        app:boxBackgroundColor="@android:color/white"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                        app:startIconTint="#64748B">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etChillerTemp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#1E293B" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView
                        android:id="@+id/tvTempWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="⚠️ Suhu chiller kurang dingin! Standar: &lt; 5°C"
                        android:textColor="#FFCDD2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. KONFIRMASI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0FDF4"
                app:strokeWidth="1dp"
                app:strokeColor="#DCFCE7">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Saya menyatakan sampel sudah aman di dalam chiller."
                        android:textColor="#166534"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchConfirmSafety"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:useMaterialThemeColors="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitSafety"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:layout_gravity="bottom"
        android:text="SELESAIKAN PROSEDUR"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="20dp"
        app:backgroundTint="@color/mbg_green_dark"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
