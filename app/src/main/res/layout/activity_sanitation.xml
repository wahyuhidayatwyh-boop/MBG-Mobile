<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".SanitationActivity">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-350dp"
        android:layout_marginEnd="-300dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActionBar"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llHeaderSanitation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:id="@+id/btnBackSanitation"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_wrapper"
                        android:backgroundTint="#F1F5F9"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/mbg_green_dark"
                        android:contentDescription="Back" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="sans-serif-black"
                        android:text="7. KEBERSIHAN &amp; SANITASI"
                        android:textColor="@color/mbg_green_dark"
                        android:textSize="18sp"
                        android:letterSpacing="0.02"/>
                </RelativeLayout>

                <!-- Card Status dengan Soft Shadow -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatusHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardBackgroundColor="@color/mbg_green_dark"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Penutupan Dapur"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvSanitationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-black"
                            android:text="DRAFT - DALAM PROSES"
                            android:textColor="@color/white"
                            android:textSize="18sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <!-- 1. BLOK AREA PRODUKSI INTERNAL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"
                    android:text="AREA PRODUKSI (Internal)"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <CheckBox
                            android:id="@+id/cbCookingTools"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kuali, panci, spatula sudah dicuci bersih."
                            android:textSize="13sp"
                            android:padding="8dp"
                            app:buttonTint="@color/mbg_green_primary" />

                        <CheckBox
                            android:id="@+id/cbPrepTables"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kompor &amp; meja dilap bebas minyak."
                            android:textSize="13sp"
                            android:padding="8dp"
                            app:buttonTint="@color/mbg_green_primary" />

                        <CheckBox
                            android:id="@+id/cbFloorClean"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lantai dapur disapu &amp; dipel disinfektan."
                            android:textSize="13sp"
                            android:padding="8dp"
                            app:buttonTint="@color/mbg_green_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPhotoKitchen"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FOTO BUKTI DAPUR BERSIH"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:cornerRadius="16dp"
                            app:backgroundTint="#F0F9FF"
                            android:textColor="@color/mbg_green_primary"
                            android:fontFamily="sans-serif-bold"/>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardPhotoKitchenPreview"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="16dp"
                            android:visibility="gone"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F1F5F9">
                            <ImageView
                                android:id="@+id/ivPhotoKitchenPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Kitchen Preview" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. BLOK RETUR KOTAK MAKAN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"
                    android:text="RETUR KOTAK MAKAN (Jam 14:00+)"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Jumlah Kotak Kembali"
                            app:boxBackgroundColor="#F8FAFC"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etReturnCount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="16sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilReturnReason"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Alasan jika ada kotak hilang"
                            android:visibility="gone"
                            app:boxBackgroundColor="#FFF1F2"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etReturnReason"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <CheckBox
                            android:id="@+id/cbBoxesWashed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Semua kotak dicuci sabun food grade."
                            android:textSize="13sp"
                            android:padding="8dp"
                            app:buttonTint="@color/mbg_green_primary" />

                        <CheckBox
                            android:id="@+id/cbBoxesStored"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kotak ditiriskan &amp; disimpan di rak tertutup."
                            android:textSize="13sp"
                            android:padding="8dp"
                            app:buttonTint="@color/mbg_green_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. MANAJEMEN SAMPAH -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"
                    android:text="MANAJEMEN SAMPAH &amp; HAMA"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <CheckBox
                            android:id="@+id/cbWasteOut"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="Limbah sisa makanan TELAH DIBUANG ke luar."
                            android:textSize="13sp"
                            app:buttonTint="@color/mbg_green_primary" />

                        <CheckBox
                            android:id="@+id/cbBinClean"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="Tong sampah kosong &amp; bersih untuk besok."
                            android:textSize="13sp"
                            app:buttonTint="@color/mbg_green_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Action Bar dengan Soft Shadow Elevation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSanitation"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_margin="24dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="SIMPAN PROGRESS"
            android:textColor="@color/white"
            app:backgroundTint="@color/mbg_green_dark"
            app:cornerRadius="20dp"
            app:elevation="4dp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
