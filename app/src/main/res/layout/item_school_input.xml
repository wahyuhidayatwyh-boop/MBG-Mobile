<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbSelectSchool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:buttonTint="@color/mbg_green_dark"
                app:useMaterialThemeColors="false" />

            <TextView
                android:id="@+id/tvSchoolNameInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/cbSelectSchool"
                android:layout_toStartOf="@id/containerTotalPorsi"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="NAMA SEKOLAH"
                android:fontFamily="sans-serif-black"
                android:textColor="#1E293B"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/containerTotalPorsi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTotalPorsiSekolah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/mbg_green_dark"
                    android:textSize="20sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PORSI"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Rincian Gizi -->
        <LinearLayout
            android:id="@+id/layoutPorsiCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="40dp"
            android:orientation="vertical">

            <TextView android:id="@+id/tvPorsi13"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GIZI A (KELAS 1-3): 0" android:textSize="11sp" android:textColor="#059669"
                android:background="#ECFDF5" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                android:fontFamily="sans-serif-black" android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <TextView android:id="@+id/tvPorsi46"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GIZI B (KELAS 4-6): 0" android:textSize="11sp" android:textColor="#0369A1"
                android:background="#F0F9FF" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                android:fontFamily="sans-serif-black" android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <TextView android:id="@+id/tvPorsiSMP"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GIZI B (SMP): 0" android:textSize="11sp" android:textColor="#475569"
                android:background="#F1F5F9" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                android:fontFamily="sans-serif-black" android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <TextView android:id="@+id/tvPorsiSMA"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GIZI B (SMA/3B): 0" android:textSize="11sp" android:textColor="#475569"
                android:background="#F1F5F9" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                android:fontFamily="sans-serif-black"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView android:id="@+id/tvSchoolAddressInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <EditText android:id="@+id/etSchoolMenuInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/cardSchoolMenuPhoto" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivSchoolMenuThumb" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>