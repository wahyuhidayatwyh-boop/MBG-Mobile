<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="#E2E8F0"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengecekan Kualitas AI"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#1E293B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analisis visual boks makanan otomatis"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- Area Kamera (Tanpa Card, Menggunakan Rounded Frame) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="#F8FAFC"
                android:clipToOutline="true"
                android:outlineProvider="background">
                <!-- Background rounded akan didapat dari clipping -->

                <androidx.camera.view.PreviewView
                    android:id="@+id/previewViewScan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageView
                    android:id="@+id/ivAiPreviewDialog"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Area Hasil (Simple Background) -->
            <LinearLayout
                android:id="@+id/cardAiResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="#F0F9FF"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#0284C7" />

                <TextView
                    android:id="@+id/tvAiResultDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Menganalisis..."
                    android:textColor="#0369A1"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCaptureAI"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:text="AMBIL FOTO"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/mbg_green_primary" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
