<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C"
    tools:context=".SchoolRatingActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#103A5C"
        android:orientation="horizontal"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:gravity="top"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackRating"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                android:rotation="360"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENILAIAN"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:alpha="0.7" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating Layanan"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="100dp">

            <!-- Title Info Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BERI FEEDBACK ANDA"
                android:textColor="@color/mbg_slate_500"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="6dp"/>

            <!-- Vendor Rating Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVendorRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="@color/white"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivVendorLogo"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:padding="10dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/logo_mbg"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                            android:background="@color/white"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F1F5F9" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kualitas Menu"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:id="@+id/tvTargetVendorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nama Dapur"
                                android:textColor="@color/mbg_slate_500"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <RatingBar
                        android:id="@+id/ratingBarVendor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:theme="@style/Widget.AppCompat.RatingBar"
                        android:progressTint="#F59E0B"
                        android:scaleX="0.9"
                        android:scaleY="0.9"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#103A5C"
                        app:hintTextColor="#103A5C"
                        app:boxStrokeWidth="1dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReviewVendor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tulis ulasan Anda (Opsional)..."
                            android:textSize="13sp"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:maxLines="4"
                            android:gravity="top"
                            android:fontFamily="sans-serif-medium" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Driver Rating Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDriverRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="@color/white"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivDriverPhotoRating"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                            android:background="@color/white"
                            android:padding="2dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F1F5F9" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ketepatan Waktu"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black" />
                            <TextView
                                android:id="@+id/tvTargetDriverName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nama Kurir"
                                android:textColor="@color/mbg_slate_500"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <RatingBar
                        android:id="@+id/ratingBarDriver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:theme="@style/Widget.AppCompat.RatingBar"
                        android:progressTint="#F59E0B"
                        android:scaleX="0.9"
                        android:scaleY="0.9"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxCornerRadiusTopStart="20dp"
                        app:boxCornerRadiusTopEnd="20dp"
                        app:boxCornerRadiusBottomStart="20dp"
                        app:boxCornerRadiusBottomEnd="20dp"
                        app:boxStrokeColor="#103A5C"
                        app:hintTextColor="#103A5C"
                        app:boxStrokeWidth="1dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReviewDriver"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ulasan kurir (Opsional)..."
                            android:textSize="13sp"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:maxLines="4"
                            android:gravity="top"
                            android:fontFamily="sans-serif-medium" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Button Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitAllRatings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginVertical="16dp"
            android:text="KIRIM PENILAIAN"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="20dp"
            android:backgroundTint="#103A5C"
            app:elevation="4dp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
