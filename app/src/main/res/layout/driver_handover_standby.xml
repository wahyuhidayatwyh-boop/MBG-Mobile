<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-320dp"
        android:layout_marginEnd="-280dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 1. Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/cardStatusBadge"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:id="@+id/tvDriverGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halo, Driver"
                        android:textColor="@color/mbg_green_dark"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tvVehicleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Memuat Kendaraan..."
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Status Standby: Hijau -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F0FDF4"
                    app:strokeWidth="1dp"
                    app:strokeColor="#DCFCE7">
                    <TextView
                        android:id="@+id/tvPulseInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="STANDBY"
                        android:textColor="#16A34A"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- 2. QR Code Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQRCodeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="32dp">

                    <FrameLayout
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/bg_dashed_manifest"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivQRCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:alpha="0.1" />

                        <!-- Locked Overlay -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/layoutQRLock"
                            android:layout_width="180dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="6dp"
                            app:cardBackgroundColor="@android:color/white"
                            app:strokeWidth="1dp"
                            app:strokeColor="#F1F5F9">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="20dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_lock_lock"
                                    app:tint="#CBD5E1" />
                                <TextView
                                    android:id="@+id/tvLockMessage"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Lengkapi SOP\ndahulu"
                                    android:textAlignment="center"
                                    android:textColor="#94A3B8"
                                    android:layout_marginTop="12dp"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-black" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. SOP Checklist Section -->
            <TextView
                android:id="@+id/tvSopTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KONFIRMASI KESELAMATAN (SOP)"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp" />

            <!-- SOP 1 Card (Dinamis: Sehat / Wadah Lengkap) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChecklistHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp" android:gravity="center_vertical">
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbHealthy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/mbg_green_primary" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvSopTitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kondisi Kurir Sehat &amp; Fit"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvSopDesc1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verifikasi suhu tubuh &amp; prokes"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SOP 2 Card (Dinamis: Steril / Area Cargo Bersih) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChecklistBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp" android:gravity="center_vertical">
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbBoxClean"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/mbg_green_primary" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvSopTitle2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Boks Makanan Steril &amp; Higienis"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvSopDesc2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pastikan area kargo bersih &amp; aman"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 4. Floating Bottom Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomStatusBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#003366"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView
            android:id="@+id/tvStatusBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="MENUNGGU SCAN DAPUR"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>