<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- Modern Background Motif -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-300dp"
        android:layout_marginEnd="-250dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginStart="-200dp"
        android:layout_marginTop="100dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="40dp">

            <!-- Header Section with padding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/logo_mbg"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MBG-SHIELD"
                    android:textAlignment="center"
                    android:textColor="@color/mbg_green_dark"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.02" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Platform real-time untuk memantau alur pangan dengan bukti digital demi keamanan dan transparansi Makan Bergizi Gratis."
                    android:textAlignment="center"
                    android:textColor="@color/mbg_green_dark"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />
            </LinearLayout>

            <!-- Edge-to-edge Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/mbg" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="MASUK KE AKUN"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/mbg_green_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="DAFTAR SEKARANG"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/mbg_green_dark"
            app:strokeColor="@color/mbg_green_dark"
            app:cornerRadius="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="Versi 1.0.0 - MBG Shield"
            android:textColor="@color/mbg_slate_400"
            android:textSize="11sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
