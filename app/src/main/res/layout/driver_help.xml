<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".DriverHelpActivity">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-320dp"
        android:layout_marginEnd="-280dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.08"
        app:layout_anchorGravity="top|end" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PUSAT BANTUAN"
                        android:textColor="@color/mbg_green_dark"
                        android:fontFamily="sans-serif-black"
                        android:textSize="18sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laporkan kendala darurat Anda"
                        android:textColor="@color/mbg_slate_500"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- ACTIVE ISSUE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveIssue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FEF2F2"
                app:strokeWidth="1dp"
                app:strokeColor="#FEE2E2"
                android:visibility="gone"
                tools:visibility="visible">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_dialog_alert" app:tint="#EF4444" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Laporan Berlangsung"
                            android:textColor="#991B1B"
                            android:fontFamily="sans-serif-black"
                            android:textSize="15sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvCurrentIssueMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Memuat kendala..."
                        android:textColor="#991B1B"
                        android:textSize="13sp" />
                    <ImageView
                        android:id="@+id/ivCurrentIssuePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResolveIssue"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="KENDALA SELESAI"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#16A34A" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutMainButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PILIH JENIS KENDALA" android:fontFamily="sans-serif-black" android:textSize="11sp" android:textColor="@color/mbg_slate_500" android:letterSpacing="0.1" android:layout_marginBottom="16dp" />

                <!-- KARTU 1: MOGOK (KE DAPUR) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnIssueMogok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_wrapper" android:backgroundTint="#FEF2F2" android:padding="10dp" android:src="@android:drawable/ic_dialog_alert" app:tint="#EF4444" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kendaraan Mogok" android:fontFamily="sans-serif-black" android:textColor="#1E293B" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lapor Armada Cadangan ke Dapur" android:textColor="#EF4444" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- KARTU 2: KENDALA SEKOLAH -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnIssueSekolah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:gravity="center_vertical">
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_wrapper" android:backgroundTint="#F0FDF4" android:padding="10dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/mbg_green_dark" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lapor Kendala Sekolah" android:fontFamily="sans-serif-black" android:textColor="#1E293B" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lapor Macet / Delay ke Sekolah" android:textColor="#64748B" android:textSize="11sp"/>
                        </LinearLayout>
                        <ImageView android:id="@+id/ivArrowSekolah" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" app:tint="#CBD5E1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FORM DETAIL UNTUK SEKOLAH (Hidden by default) -->
                <LinearLayout
                    android:id="@+id/layoutSekolahForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp" app:hintEnabled="false">
                        <AutoCompleteTextView android:id="@+id/spinnerIssueType" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pilih Kategori Kendala" android:inputType="none" android:padding="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp" app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etIssueDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Jelaskan detail kendala..." android:inputType="textMultiLine" android:lines="3" android:gravity="top" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCapturePhoto"
                        android:layout_width="match_parent" android:layout_height="120dp" android:layout_marginBottom="16dp"
                        app:cardCornerRadius="20dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="#E2E8F0" app:cardBackgroundColor="#F8FAFC">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                            <ImageView android:id="@+id/ivPreview" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:visibility="gone" />
                            <TextView android:id="@+id/tvPhotoPlaceholder" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Klik untuk Ambil Foto" android:textColor="#94A3B8" android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitSekolah"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="KIRIM LAPORAN KE SEKOLAH"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/mbg_green_dark" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- MODERN FLOATING BOTTOM NAVIGATION -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/white"
            app:menu="@menu/driver_bottom_menu"
            app:itemIconTint="@color/mbg_green_dark"
            app:itemTextColor="@color/mbg_green_dark"
            app:itemRippleColor="@color/mbg_green_light"
            app:labelVisibilityMode="labeled"
            app:elevation="0dp"
            app:itemActiveIndicatorStyle="@style/App.BottomNavigationView.ActiveIndicator" />
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>