<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ReportIssueActivity">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-300dp"
        android:layout_marginEnd="-250dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.1"
        app:layout_anchorGravity="top|end" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/btnBackIssue"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_wrapper"
                    android:backgroundTint="#F1F5F9"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#EF4444"
                    android:contentDescription="Back" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAPOR KENDALA"
                        android:textColor="#EF4444"
                        android:fontFamily="sans-serif-black"
                        android:textSize="18sp"
                        android:letterSpacing="0.02"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Komando MBG-SHIELD"
                        android:textColor="#64748B"
                        android:textSize="11sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- WARNING INFO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#FEF2F2"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FEE2E2">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="#EF4444" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Laporan Anda akan langsung dipantau oleh tim pusat untuk penanganan darurat."
                        android:textColor="#991B1B"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 1. PILIH KATEGORI KENDALA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PILIH KATEGORI"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <GridLayout
                android:id="@+id/gridCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="32dp">

                <!-- Alat Rusak -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCatEquipment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cat_card_icon_selector"
                    app:cardBackgroundColor="@color/cat_card_bg_selector"
                    app:checkedIconTint="#EF4444"
                    android:clickable="true"
                    android:focusable="true"
                    android:checkable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/ivCatEquipment"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            app:tint="@color/cat_card_icon_selector" />
                        <TextView
                            android:id="@+id/tvCatEquipment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Alat Rusak"
                            android:textColor="@color/cat_card_text_selector"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Logistik -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCatLogistics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cat_card_icon_selector"
                    app:cardBackgroundColor="@color/cat_card_bg_selector"
                    app:checkedIconTint="#EF4444"
                    android:clickable="true"
                    android:focusable="true"
                    android:checkable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/ivCatLogistics"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="@color/cat_card_icon_selector" />
                        <TextView
                            android:id="@+id/tvCatLogistics"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Bahan Baku"
                            android:textColor="@color/cat_card_text_selector"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SDM -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCatPersonnel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cat_card_icon_selector"
                    app:cardBackgroundColor="@color/cat_card_bg_selector"
                    app:checkedIconTint="#EF4444"
                    android:clickable="true"
                    android:focusable="true"
                    android:checkable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/ivCatPersonnel"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/cat_card_icon_selector" />
                        <TextView
                            android:id="@+id/tvCatPersonnel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Tim/SDM"
                            android:textColor="@color/cat_card_text_selector"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Listrik/Air -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCatPower"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cat_card_icon_selector"
                    app:cardBackgroundColor="@color/cat_card_bg_selector"
                    app:checkedIconTint="#EF4444"
                    android:clickable="true"
                    android:focusable="true"
                    android:checkable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/ivCatPower"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/stat_sys_warning"
                            app:tint="@color/cat_card_icon_selector" />
                        <TextView
                            android:id="@+id/tvCatPower"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Utilitas (Air/Gas)"
                            android:textColor="@color/cat_card_text_selector"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- 2. DESKRIPSI KENDALA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETAIL KENDALA"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Jelaskan detail masalah..."
                    app:boxBackgroundColor="@android:color/white"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:placeholderTextColor="#94A3B8">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etIssueDescription"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. BUKTI FOTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOTO BUKTI"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnAttachPhoto"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#F8FAFC"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/ivIssuePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#CBD5E1"
                        android:padding="60dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="20dp"
                        android:text="Ketuk untuk Ambil Foto"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SUBMIT BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitIssue"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="KIRIM LAPORAN SEKARANG"
                android:fontFamily="sans-serif-black"
                app:cornerRadius="20dp"
                app:backgroundTint="#EF4444"
                app:elevation="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>