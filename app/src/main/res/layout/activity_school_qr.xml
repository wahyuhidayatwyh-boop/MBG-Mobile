<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C"
    tools:context=".SchoolQRActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#103A5C"
        android:orientation="horizontal"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:gravity="top"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackQR"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:id="@+id/tvLabelQR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFIKASI"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:alpha="0.7" />
            <TextView
                android:id="@+id/tvSchoolNameQR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR Kehadiran"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- QR Code Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1.5dp"
                app:strokeColor="#F1F5F9"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC"
                        app:strokeWidth="2dp"
                        app:strokeColor="#F1F5F9">
                        <ImageView
                            android:id="@+id/ivSchoolQR"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="24dp"
                            android:scaleType="fitCenter" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvStatusLabelQR"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="TOKEN KEAMANAN AKTIF"
                        android:textColor="#10B981"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvInstructionQR"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Tunjukkan kode ini kepada kurir\nuntuk proses verifikasi serah terima"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Security Label -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:alpha="0.6">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_lock_lock"
                    app:tint="#103A5C" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Sistem Verifikasi Terenkripsi"
                    android:textColor="#103A5C"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>