<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-320dp"
        android:layout_marginEnd="-280dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 1. FORM UTAMA (Scrollable) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/formScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:clipChildren="false">

            <!-- Header Section (Fixed Overlap) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSchoolBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F5F9">
                    <TextView
                        android:id="@+id/tvSchoolTarget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="SDN 1 Purwokerto"
                        android:textColor="#475569"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/cardSchoolBadge"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KONFIRMASI"
                        android:textColor="@color/mbg_green_dark"
                        android:fontFamily="sans-serif-black"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="BUKTI PENGIRIMAN"
                        android:textColor="@color/mbg_green_dark"
                        android:textSize="22sp" />
                </LinearLayout>
            </RelativeLayout>

            <TextView
                android:id="@+id/tvDropSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Target: 300 Boks Makanan"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <!-- STEP 1: SCAN QR GURU -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStepScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E1F5FE"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/mbg_green_primary" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:fontFamily="sans-serif-black"
                            android:text="1. Verifikasi QR Guru"
                            android:textColor="#1E293B" />
                        <ImageView
                            android:id="@+id/ivScanCheck"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/checkbox_on_background"
                            app:tint="#10B981"
                            android:visibility="gone" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenScanner"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="BUKA SCANNER LIVE"
                        android:fontFamily="sans-serif-black"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#F0F9FF"
                        android:textColor="@color/mbg_green_primary" />

                    <TextView
                        android:id="@+id/tvScanStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Status: Belum Terverifikasi"
                        android:textAlignment="center"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 2: FOTO MUATAN -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStepPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="2. Foto Bukti Serah Terima"
                        android:textColor="#1E293B" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTakePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="AMBIL FOTO"
                        android:fontFamily="sans-serif-black"
                        app:cornerRadius="16dp" />
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPhotoPreviewDrop"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 3: TANDA TANGAN -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStepSignature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="3. Tanda Tangan Digital"
                            android:textColor="#1E293B" />
                        <TextView
                            android:id="@+id/btnClearSignature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="HAPUS"
                            android:textColor="@color/error_red"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="#F8FAFC"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0">
                        <com.why.mbgdapur.SignatureView
                            android:id="@+id/signaturePad"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Tombol Selesai (Fixed Bottom) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutFinishBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinishDelivery"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_margin="24dp"
            android:text="KONFIRMASI SELESAI"
            android:enabled="false"
            android:alpha="0.5"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="20dp"
            app:backgroundTint="@color/mbg_green_dark" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 2. OVERLAY SCANNER LIVE (Desain Premium) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLiveScanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewViewProof"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Motif Background di Scanner Overlay -->
        <View
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_marginTop="-200dp"
            android:layout_marginEnd="-150dp"
            android:background="@drawable/bg_circle_accent"
            android:alpha="0.15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#90000000" />

        <!-- Bingkai Scanner Premium -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="280dp"
            android:layout_height="280dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="48dp"
            app:strokeWidth="4dp"
            app:strokeColor="@color/mbg_green_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFIKASI GURU"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Scan barcode di HP Guru untuk konfirmasi tiba"
                android:textColor="#CBD5E1"
                android:textAlignment="center"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseScanner"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="KEMBALI KE FORM"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>