<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutSwipeContainer"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 1. Header Sukses -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="42dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_green"
                    android:contentDescription="Success Icon" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="SCAN BERHASIL!"
                android:textColor="@color/mbg_green_dark"
                android:textSize="22sp"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Surat jalan digital telah diterbitkan. Silakan kroscek muatan Anda."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <!-- 2. Kartu Manifest -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@drawable/bg_dashed_manifest">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:text="TOTAL MUATAN"
                        android:textColor="#94A3B8"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvTotalManifest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="500 Boks"
                        android:textColor="#1E293B"
                        android:textSize="44sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="24dp"
                        android:background="#F1F5F9" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KENDARAAN" android:textColor="#94A3B8" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                            <TextView android:id="@+id/tvVehicle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobil Box (R 9999 XX)" android:textColor="#1E293B" android:textSize="13sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.6"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WAKTU" android:textColor="#94A3B8" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                            <TextView android:id="@+id/tvTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="08:15 WIB" android:textColor="#1E293B" android:textSize="13sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Photo Proof Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-black"
                android:text="DOKUMENTASI BUKTI MUAT"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCapturePhoto"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="2dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="#F8FAFC"
                android:clickable="true"
                android:focusable="true">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/layoutCaptureInstruction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#94A3B8"
                            android:contentDescription="Camera Icon" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Ambil Foto Muatan di Kendaraan"
                            android:textColor="#94A3B8"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPhotoPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Photo Preview" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPhotoSuccess"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="12dp"
                        app:cardBackgroundColor="#10B981"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_green"
                            app:tint="@android:color/white"
                            android:contentDescription="Check Icon" />
                    </com.google.android.material.card.MaterialCardView>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 5. Action Swipe (BIRU KONSISTEN SEJAK AWAL) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutSwipeContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/mbg_green_dark"
        app:layout_constraintBottom_toBottomOf="parent"
        android:alpha="0.6">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvSwipeHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:text="GESER UNTUK BERANGKAT"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/swipeThumb"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="34dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/mbg_green_dark"
                    android:contentDescription="Swipe Action" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>