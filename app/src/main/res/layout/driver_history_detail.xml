<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:id="@+id/btnBackDetail"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/mbg_green_dark"
                    android:contentDescription="Back" />
                <TextView
                    android:id="@+id/tvTitleHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="sans-serif-black"
                    android:text="DETAIL RIWAYAT"
                    android:textColor="@color/mbg_green_dark"
                    android:textSize="18sp"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/tvSchoolNameDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Sekolah"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#1E293B"/>

            <TextView
                android:id="@+id/tvDateDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tanggal"
                android:textColor="#64748B"
                android:layout_marginBottom="24dp"/>

            <!-- SECTION MANIFEST -->
            <LinearLayout
                android:id="@+id/layoutManifestInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFORMASI MANIFEST"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/mbg_green_dark"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvTotalMuatanDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Muatan: 0 Boks"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FOTO BUKTI MUAT"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp">
                    <ImageView
                        android:id="@+id/ivManifestPhotoFull"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Manifest" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- SECTION PENGIRIMAN (DELIVERY) -->
            <LinearLayout
                android:id="@+id/layoutDeliveryInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETAIL PENGANTARAN"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#16A34A"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUKTI TERIMA (POD)"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp">
                    <ImageView
                        android:id="@+id/ivPodPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto POD" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TANDA TANGAN PENERIMA"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">
                    <ImageView
                        android:id="@+id/ivSignature"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:contentDescription="Tanda Tangan" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- SECTION PENJEMPUTAN (RETUR) -->
            <LinearLayout
                android:id="@+id/layoutReturInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETAIL PENJEMPUTAN BOKS"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#3B82F6"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvReturBoxCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Boks Kotor: 0"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUKTI JEMPUT"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp">
                    <ImageView
                        android:id="@+id/ivReturPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Retur" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TANDA TANGAN GURU / PETUGAS"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">
                    <ImageView
                        android:id="@+id/ivReturSignature"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:contentDescription="Tanda Tangan Retur" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
