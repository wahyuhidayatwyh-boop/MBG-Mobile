<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C"
    tools:context=".SchoolCourierTrackingActivity">

    <!-- Area Peta menggunakan WebView -->
    <WebView
        android:id="@+id/webViewTracking"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Navigation Overlay -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#103A5C"
        app:strokeWidth="1.5dp"
        app:strokeColor="#33FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBackTracking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_revert"
                android:rotation="360"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="LACAK PENGIRIMAN"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ISSUE NOTIFICATION CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDriverIssue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFF1F2"
        app:strokeWidth="1.5dp"
        app:strokeColor="#FECDD3"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/topBar">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    app:tint="#E11D48" />
                <TextView
                    android:id="@+id/tvIssueTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="KENDALA KURIR"
                    android:textColor="#9F1239"
                    android:fontFamily="sans-serif-black"
                    android:textSize="13sp" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvIssueDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Deskripsi kendala..."
                android:textColor="#BE123C"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivIssuePhoto"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Delivery Info Bottom Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="#F1F5F9"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F5F9">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@android:drawable/ic_menu_directions"
                        app:tint="#103A5C" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvDeliveryStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PENGIRIMAN MENUJU LOKASI"
                        android:textColor="#103A5C"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/tvLastUpdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mendeteksi lokasi kurir..."
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#F1F5F9"
                android:layout_marginVertical="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivDriverPhoto"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    android:background="#F1F5F9"
                    android:padding="2dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Kurir"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tvDriverVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plat Nomor Kendaraan"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCallDriver"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    app:cardCornerRadius="27dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#103A5C"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@color/white" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>