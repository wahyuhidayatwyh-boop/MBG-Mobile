<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".DashboardActivity">

    <!-- Motif Background Modern -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginTop="-300dp"
        android:layout_marginEnd="-250dp"
        android:background="@drawable/bg_circle_accent"
        android:alpha="0.04"
        app:layout_anchorGravity="top|end" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Bekerja,"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:id="@+id/tvVendorNameDashboard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NAMA DAPUR"
                        android:textColor="@color/mbg_green_dark"
                        android:fontFamily="sans-serif-black"
                        android:textSize="24sp"
                        android:letterSpacing="-0.01"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#94A3B8"/>
                        <TextView
                            android:id="@+id/tvVendorLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Lokasi Dapur"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnLogoutVendor"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF1F2"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FFE4E6">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="11dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="#F43F5E" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- 1. MAIN SUMMARY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/mbg_green_dark"
                app:cardCornerRadius="32dp"
                app:cardElevation="10dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="26dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RINGKASAN HARIAN"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.15"/>
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatusProduksi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F59E0B">
                            <TextView
                                android:id="@+id/tvStatusProduksi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="MEMUAT..."
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-black"/>
                        </com.google.android.material.card.MaterialCardView>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TARGET PORSI"
                                android:textColor="#B3FFFFFF"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:id="@+id/tvTargetCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.6"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MENU UTAMA"
                                android:textColor="#B3FFFFFF"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:id="@+id/tvTargetMenu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewOrderDetails"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat Detail Pesanan →"
                        android:textColor="#93C5FD"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:padding="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:layout_marginTop="8dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15FFFFFF" android:layout_marginVertical="20dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RATING" android:textColor="#94A3B8" android:textSize="9sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.05"/>
                            <TextView android:id="@+id/tvVendorRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0" android:textColor="#FFFFFF" android:textSize="20sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="30dp" android:background="#15FFFFFF" android:layout_gravity="center_vertical" android:layout_marginHorizontal="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KEPATUHAN" android:textColor="#94A3B8" android:textSize="9sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.05"/>
                            <TextView android:id="@+id/tvIntegrityScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#10B981" android:textSize="20sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FASE PRODUKSI SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FASE PRODUKSI &amp; QC"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="24dp">

                <!-- Persiapan (Blue Accent) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuPrepMorning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/persiapan"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#DBEAFE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Persiapan"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bahan &amp; Alat"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Masak (Orange Accent) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuCookingProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/masak"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#FFEDD5"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Proses Masak"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update Progres"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Visual AI (Purple Accent) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuVisualAI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/visual"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#EDE9FE"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Visual AI"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verifikasi Porsi"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sampel (Green Accent) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuFoodSafety"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/sampel"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#DCFCE7"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Sampel"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Uji Food Safety"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGISTIK &amp; AKHIR SHIFT"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:layout_marginBottom="28dp">

                <!-- Pengiriman (Pink) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuDistribution"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/pengiriman"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#FCE7F3"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Pengiriman"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Serah Terima"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Wadah Balik (Slate) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuReturnWadah"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/wadah_balik"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#F1F5F9"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Wadah Balik"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cek Pengembalian"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sanitasi (Teal) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuSanitation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/sanitasi"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#D1FAE5"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Sanitasi"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kebersihan Dapur"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Laporan (Indigo) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuFinalReport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#F1F5F9"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/laporan"
                            android:background="@drawable/bg_icon_wrapper"
                            android:backgroundTint="#E0E7FF"
                            android:padding="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Laporan"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/mbg_green_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ringkasan Akhir"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- EMERGENCY PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/menuPanic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF1F2"
                app:strokeWidth="1dp"
                app:strokeColor="#FFE4E6">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="#F43F5E"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pusat Bantuan Darurat"
                            android:textColor="#9F1239"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Laporkan kendala operasional segera"
                            android:textColor="#F43F5E"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FOOTER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/logo_mbg"
                    android:alpha="0.15" />
                <TextView
                    android:layout_width="wrap_content"
