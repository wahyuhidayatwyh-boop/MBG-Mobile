<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#103A5C"
    tools:context=".SchoolHistoryActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#103A5C"
        android:orientation="horizontal"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:gravity="top"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                android:rotation="360"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAPORAN"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:alpha="0.7" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Pesanan"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content Body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_top_white"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp">

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1.5dp"
                app:strokeColor="#F1F5F9"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL PESANAN"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvTotalHistoryCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Pesanan"
                            android:textColor="#103A5C"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#F1F5F9"
                        android:layout_marginHorizontal="20dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL PORSI"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvTotalHistoryPorsi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Porsi"
                            android:textColor="#103A5C"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchoolHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:paddingBottom="32dp" />

            <LinearLayout
                android:id="@+id/layoutEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="60dp"
                android:visibility="gone">
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/logo_mbg"
                    android:alpha="0.1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Belum ada riwayat pesanan"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Navigation Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <!-- Beranda -->
            <LinearLayout
                android:id="@+id/navBeranda"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_home_selector" />
                <TextView
                    android:id="@+id/tvNavHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Beranda"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Menu -->
            <LinearLayout
                android:id="@+id/navMenu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavMenu"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_menu_selector" />
                <TextView
                    android:id="@+id/tvNavMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Menu"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Riwayat -->
            <LinearLayout
                android:id="@+id/navHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavHistory"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_history_selector" />
                <TextView
                    android:id="@+id/tvNavHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Riwayat"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- Akun -->
            <LinearLayout
                android:id="@+id/navAkun"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/ivNavAccount"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/nav_account_selector" />
                <TextView
                    android:id="@+id/tvNavAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:duplicateParentState="true"
                    android:text="Akun"
                    android:textSize="11sp"
                    android:textColor="@color/nav_text_selector"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>