<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="40dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_accent"
            android:backgroundTint="#F0F9FF">
            <ImageView
                android:id="@+id/ivExitIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@color/mbg_green_primary"
                android:contentDescription="Exit Icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvExitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Konfirmasi Sesi"
            android:textColor="#1E293B"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvExitMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Apakah Anda yakin ingin keluar?"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelExit"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="BATAL"
                android:textColor="#64748B"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmExit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:layout_marginStart="6dp"
                android:text="YA, KELUAR"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/mbg_green_primary"
                android:textColor="@color/white"
                app:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
