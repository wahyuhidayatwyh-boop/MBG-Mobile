<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 1. Area Peta menggunakan WebView -->
    <WebView
        android:id="@+id/webViewMap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.6"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Informasi Tujuan (Floating Card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDestination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-40dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E1F5FE"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/webViewMap">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvStopIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pemberhentian 1 dari 2"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTargetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SDN 1 Purwokerto"
                android:textColor="@color/mbg_green_dark"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvTaskDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tugas: Turunkan 300 Boks"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F5F9"
                android:layout_marginVertical="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESTIMASI" android:textSize="9sp" android:textColor="#94A3B8" android:fontFamily="sans-serif-black"/>
                    <TextView android:id="@+id/tvETA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 Menit" android:textColor="#1E293B" android:textSize="16sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JARAK" android:textSize="9sp" android:textColor="#94A3B8" android:fontFamily="sans-serif-black"/>
                    <TextView android:id="@+id/tvDistance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2.4 KM" android:textColor="#10B981" android:textSize="16sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 3. Tombol Quick Action -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardDestination">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallSchool"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="CALL"
            android:textSize="11sp"
            android:paddingHorizontal="4dp"
            app:icon="@android:drawable/ic_menu_call"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenExternalMap"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.3"
            android:layout_marginHorizontal="4dp"
            android:text="NAVIGASI"
            android:textSize="11sp"
            android:paddingHorizontal="4dp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReportIssue"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.1"
            android:layout_marginStart="4dp"
            android:text="BANTUAN"
            android:textSize="11sp"
            android:paddingHorizontal="4dp"
            app:icon="@android:drawable/ic_dialog_alert"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <!-- 4. Tombol Utama TIBA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnArrived"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="20dp"
        android:text="SAYA SUDAH TIBA"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="20dp"
        app:backgroundTint="@color/mbg_green_dark"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
